{
  "name": "@ali-dev/storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --config-dir src/storybook-config",
    "build": "storybook build --config-dir src/storybook-config",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "npm-run-all --parallel lint:*",
    "lint:eslint": "eslint . --cache \"**/*.{js,jsx,ts,tsx}\"",
    "lint-fix": "npm-run-all --parallel lint-fix:*",
    "lint-fix:eslint": "eslint . --cache --fix \"**/*.{js,jsx,ts,tsx}\"",
    "lint-fix:prettier": "prettier --write '**/*.{js,jsx,ts,tsx,json,scss}'"
  },
  "dependencies": {
    "@ali-dev/theme": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@ali-dev/components": "workspace:*",
    "@chromatic-com/storybook": "5.0.1",
    "next": "16.1.6",
    "@storybook/addon-docs": "10.2.19",
    "@storybook/nextjs-vite": "10.2.19",
    "@storybook/react": "10.2.19",
    "@storybook/preset-scss": "1.0.3",
    "@types/node": "24",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "highlight.js": "11.11.1",
    "rimraf": "6.1.3",
    "storybook": "10.2.19",
    "storybook-addon-pseudo-states": "10.2.19",
    "style-loader": "4.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "typescript-eslint": "8.57.0",
    "vite": "8",
    "vite-plugin-svgr": "4.5.0"
  },
  "packageManager": "pnpm@10.32.1"
}
