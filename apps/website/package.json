{
  "name": "@ali-dev/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec infisical run --env=dev -- pnpm exec next dev",
    "prebuild": "pnpm codegen",
    "build": "next build",
    "start": "next start",
    "codegen": "graphql-codegen --config src/codegen.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "playwright": "playwright test",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "npm-run-all --parallel lint:*",
    "lint:eslint": "eslint . --cache \"**/*.{js,jsx,ts,tsx}\"",
    "lint:stylelint": "stylelint \"**/*.scss\"",
    "lint-fix": "npm-run-all --parallel lint-fix:*",
    "lint-fix:eslint": "eslint . --cache --fix \"**/*.{js,jsx,ts,tsx}\"",
    "lint-fix:prettier": "prettier --write '**/*.{js,jsx,ts,tsx,json,scss}'"
  },
  "dependencies": {
    "@ali-dev/components": "workspace:*",
    "@ali-dev/theme": "workspace:*",
    "@fontsource/roboto": "5.2.10",
    "@sanity/asset-utils": "2.3.0",
    "@sanity/image-url": "2.0.3",
    "classnames": "2.5.1",
    "dotenv": "17.3.1",
    "graphql": "16.13.1",
    "lodash.last": "3.0.0",
    "lodash.uniq": "4.5.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-google-recaptcha-v3": "1.11.0",
    "react-hook-form": "7.71.2",
    "react-toastify": "11.0.5",
    "sharp": "0.34.5",
    "wretch": "3.0.7",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-typed-document-node/core": "3.2.0",
    "@playwright/test": "1.51.1",
    "@testing-library/dom": "10.1.0",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@types/jest": "29.5.12",
    "@types/lodash.last": "3.0.9",
    "@types/lodash.uniq": "4.5.9",
    "@types/node": "24",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.3.1",
    "eslint": "9.22.0",
    "eslint-config-next": "16.1.6",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-fetch-mock": "3.0.3",
    "rimraf": "5.0.1",
    "sass": "1.77.4",
    "style-loader": "4.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  },
  "packageManager": "pnpm@10.32.1"
}
