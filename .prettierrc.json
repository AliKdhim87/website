{
  "endOfLine": "auto",
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "parser": "json",
        "printWidth": 120,
        "tabWidth": 2,
        "endOfLine": "auto"
      }
    },
    {
      "files": ["package.json"],
      "options": {
        "parser": "json-stringify",
        "tabWidth": 2,
        "useTabs": false,
        "endOfLine": "auto"
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "options": {
        "parser": "typescript",
        "printWidth": 120,
        "trailingComma": "all",
        "tabWidth": 2,
        "singleQuote": true,
        "endOfLine": "auto"
      }
    },
    {
      "files": ["*.scss"],
      "options": {
        "parser": "scss",
        "tabWidth": 2,
        "endOfLine": "auto"
      }
    },
    {
      "files": ["*.html"],
      "options": {
        "parser": "html",
        "printWidth": 120,
        "tabWidth": 2,
        "endOfLine": "auto"
      }
    }
  ]
}
