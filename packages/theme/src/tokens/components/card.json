{
  "ali-dev": {
    "card": {
      "margin-block-start": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.sm}"
      },
      "background-color": {
        "$type": "color",
        "$value": "{ali-dev.colors.background-base}"
      },
      "padding-block-start": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.sm}"
      },
      "padding-block-end": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.sm}"
      },
      "padding-inline-start": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.sm}"
      },
      "padding-inline-end": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.sm}"
      },
      "transition-duration": {
        "$type": "time",
        "$value": "400ms"
      },
      "row-gap": {
        "$type": "dimension",
        "$value": "{ali-dev.spacing.md}"
      },
      "date": {
        "color": {
          "$type": "color",
          "$value": "{ali-dev.colors.grey.300}"
        },
        "margin-block-start": {
          "$type": "dimension",
          "$value": "{ali-dev.spacing.sm}"
        }
      },
      "body": {
        "margin-block-start": {
          "$type": "dimension",
          "$value": "{ali-dev.spacing.sm}"
        }
      },
      "hover": {
        "border-color": {
          "$type": "color",
          "$value": "{ali-dev.colors.tertiary-focus}"
        },
        "box-shadow": {
          "$type": "shadow",
          "$value": "0 0 12px {ali-dev.colors.tertiary-hover}"
        },
        "background-color": {
          "$type": "color",
          "$value": "{ali-dev.colors.tertiary-focus}"
        }
      }
    }
  }
}
